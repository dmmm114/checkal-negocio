# =========================================================================
# /etc/checkal/agente.env — segredos e gates dos AGENTES (Polaris)
#
# Instalar:  sudo install -m 600 -o root -g checkal agente.env /etc/checkal/agente.env
# NUNCA versionar o ficheiro real (o .gitignore já cobre .env; este .example
# não leva segredos). As chaves colam-se AQUI, diretamente no Polaris — nunca
# no repositório, nunca em docs.
# =========================================================================

# --- Caminhos (o repo vive em /opt/checkal via symlink; ver README systemd) ---
CHECKAL_BASE_DIR=/opt/checkal/checkal
CHECKAL_DB_URL=sqlite:////opt/checkal/checkal/data/checkal.db

# --- IA (Claude CLI → API Anthropic; conta COMERCIAL, não login pessoal) ---
ANTHROPIC_API_KEY=

# --- GATES (o código nasce fechado; abrir é decisão do DONO, aqui) ---
# Parecer RGPD favorável sobre reutilizar o RNAL (dono confirmou luz verde):
CHECKAL_PARECER_RGPD_OK=false
# Enquadramento DPA/transferências da Anthropic confirmado pelo dono:
CHECKAL_ANTHROPIC_DPA_OK=false
# Só desligar DEPOIS do ensaio test→live (pagamento a ti próprio + fatura AT):
CHECKAL_MODO_TESTE=true

# --- Observabilidade / escalação ao dono ---
HEALTHCHECKS_PING_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Tetos de custo LLM ---
CHECKAL_TETO_DIARIO_EUR=5
CHECKAL_TETO_AGENTE_EUR=2

# --- Faturação: TOConline, série CKL (smoke-test real ANTES da 1.ª fatura) ---
TOCONLINE_OAUTH_URL=
TOCONLINE_API_URL=
TOCONLINE_CLIENT_ID=
TOCONLINE_CLIENT_SECRET=
TOCONLINE_SERIES_ID=
TOCONLINE_SERIES_PREFIX=

# --- Pagamentos: IfThenPay (a antiphishing é OBRIGATÓRIA nos callbacks) ---
IFTHENPAY_MB_KEY=
IFTHENPAY_MBWAY_KEY=
IFTHENPAY_ANTIPHISHING_KEY=
CHECKAL_IBAN=

# --- Transacional (checkal.pt / Resend) ---
RESEND_API_KEY=

# --- COLD (domínio de envio SEPARADO — nunca checkal.pt; ver AGENTES-ENXAME) ---
COLD_SMTP_HOST=
COLD_SMTP_PORT=587
COLD_SMTP_USER=
COLD_SMTP_PASS=
# COLD_FROM=CheckAL <geral@getcheckal.com>

# --- Feed de oposição DGC (sem isto o envio frio recusa — fail-closed) ---
CHECKAL_LISTA_DGC_PATH=

# --- Web ---
CHECKAL_SECRET=
CHECKAL_ADMIN_PASSWORD=

# CheckAL — variáveis de ambiente. Copiar para .env e preencher.
# NADA de segredos reais no .env.example (fica no git); .env é ignorado.
# Regra: tudo é LIVE-GATED — uma chave vazia desliga a integração respetiva em segurança.

# ==========================================================================
#  Núcleo
# ==========================================================================
# Dev: SQLite (default). Prod: postgresql+psycopg://checkal:PASS@db:5432/checkal
CHECKAL_DB_URL=sqlite:///data/checkal.db
CHECKAL_SECRET=trocar-isto-por-64-bytes-aleatorios      # assina sessões, magic-links e o cookie do admin
CHECKAL_ADMIN_PASSWORD=                                  # password do dashboard /admin (obrigatória em prod)
CHECKAL_BASE_URL=https://checkal.pt
CHECKAL_SITE_URL=https://checkal.pt

# MODO DE TESTE: enquanto true, NADA envia/cobra/liga à rede (composição apenas).
# Só passar a false no go-live (RUNBOOK-GO-LIVE.md §5), com chaves live preenchidas.
CHECKAL_MODO_TESTE=true

# ==========================================================================
#  🚦 PORTÃO RGPD (cold / Canal B) — ver LEGAL-PARECER-DECISOES.md §4
#  NÃO ligar sem: base legal do email confirmada + LIA + Anexo 1 + art. 28.º/44.º.
# ==========================================================================
CHECKAL_PARECER_RGPD_OK=false

# ==========================================================================
#  IA (Anthropic) — triagem Haiku + redação Sonnet (Batch)
# ==========================================================================
ANTHROPIC_API_KEY=
CHECKAL_MODEL_TRIAGEM=claude-haiku-4-5-20251001
CHECKAL_MODEL_ALERTA=claude-sonnet-5

# ==========================================================================
#  Email transacional (Canal A — Resend; NUNCA usar para cold)
# ==========================================================================
RESEND_API_KEY=
CHECKAL_EMAIL_FROM=CheckAL <alertas@send.checkal.pt>
CHECKAL_EMAIL_APOIO=apoio@checkal.pt

# ==========================================================================
#  Cold / prospeção (Canal B — SMTP dedicado getcheckal.com; PARECER-GATED)
# ==========================================================================
COLD_FROM=CheckAL <ola@getcheckal.com>
COLD_SMTP_HOST=
COLD_SMTP_PORT=587
COLD_SMTP_USER=
COLD_SMTP_PASS=
CHECKAL_CAMPANHA_CAP_DIARIO=25          # throttle/warm-up do domínio frio
CHECKAL_CAMPANHA_JANELA_H=72            # janela gatilho→campanha

# ==========================================================================
#  Faturação — TOConline (fornecedor ATIVO; série nova por criar)
#  Credenciais: TOConline → Empresa → Dados API (link válido 72 h).
# ==========================================================================
CHECKAL_FATURACAO_PROVIDER=toconline
TOCONLINE_OAUTH_URL=
TOCONLINE_API_URL=
TOCONLINE_CLIENT_ID=
TOCONLINE_CLIENT_SECRET=
TOCONLINE_SERIES_ID=                     # id NUMÉRICO da série (o Diogo dá após criar)
TOCONLINE_SERIES_PREFIX=

# --- InvoiceXpress (adaptador secundário/reserva) ---
INVOICEXPRESS_ACCOUNT=
INVOICEXPRESS_API_KEY=
INVOICEXPRESS_SERIE=CKL
INVOICEXPRESS_SEQUENCE_ID=
INVOICEXPRESS_TAXA_NOME=IVA23

# ==========================================================================
#  Pagamentos
# ==========================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                   # whsec_ do endpoint https://checkal.pt/webhooks/stripe

IFTHENPAY_MB_KEY=
IFTHENPAY_MBWAY_KEY=
IFTHENPAY_ANTIPHISHING_KEY=
IFTHENPAY_BASE=https://api.ifthenpay.com

# ==========================================================================
#  Suporte 1.ª linha (IMAP de apoio@) + escalação ao dono (Telegram)
# ==========================================================================
IMAP_HOST=
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_TIMEOUT_S=10

# ==========================================================================
#  Observabilidade (dead-man switch) + backups
# ==========================================================================
HEALTHCHECKS_BASE_URL=https://hc-ping.com
HEALTHCHECKS_PING_KEY=                   # ping key do projeto no Healthchecks.io
HEALTHCHECKS_TIMEOUT_S=10

CHECKAL_BACKUP_DB_URL=                   # DSN Postgres p/ pg_dump (vazio = backup inativo)
CHECKAL_BACKUP_DIR=/var/backups/checkal
CHECKAL_BACKUP_RETENCAO_DIAS=30
CHECKAL_PGDUMP_BIN=pg_dump

# ==========================================================================
#  SMS de reforço dos alertas 🔴 (provider a definir; placeholder)
# ==========================================================================
SMS_PROVIDER_KEY=

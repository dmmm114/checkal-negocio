# CheckAL — variáveis de ambiente. Copiar para .env e preencher.
# NADA de segredos reais no .env.example (fica no git); .env é ignorado.

# --- Base de dados ---
# Dev: SQLite (default). Prod: postgresql+psycopg://user:pass@host/checkal
CHECKAL_DB_URL=sqlite:///data/checkal.db

# --- Segurança ---
CHECKAL_SECRET=trocar-isto-por-64-bytes-aleatorios      # assina sessões e magic-links
CHECKAL_ADMIN_PASSWORD=                                  # password do dashboard admin (obrigatória em prod)

# --- URLs públicas ---
CHECKAL_BASE_URL=https://checkal.pt
CHECKAL_SITE_URL=https://checkal.pt

# --- IA (Anthropic / Fable) ---
ANTHROPIC_API_KEY=
CHECKAL_MODEL_TRIAGEM=claude-haiku-4-5-20251001
CHECKAL_MODEL_ALERTA=claude-sonnet-5

# --- Email transacional (Resend) ---
RESEND_API_KEY=
CHECKAL_EMAIL_FROM=CheckAL <alertas@checkal.pt>
CHECKAL_EMAIL_APOIO=apoio@checkal.pt

# --- Pagamentos: IfThenPay (referências MB / MB WAY) ---
# Pedir ao Diogo no backoffice IfThenPay: https://backoffice.ifthenpay.com
IFTHENPAY_MB_KEY=                 # "Chave Multibanco" (gera referências MB)
IFTHENPAY_MBWAY_KEY=              # "MB WAY Key"
IFTHENPAY_PAYSHOP_KEY=            # opcional (Payshop)
IFTHENPAY_ANTIPHISHING_KEY=       # valida os callbacks de pagamento
IFTHENPAY_BASE=https://api.ifthenpay.com

# --- Pagamentos: Stripe (subscrições recorrentes cartão/SEPA) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ANUAL=               # price_id do plano anual
STRIPE_PRICE_TRIENAL=             # price_id do plano trienal

# --- Faturação certificada (InvoiceXpress) ---
INVOICEXPRESS_ACCOUNT=            # subdomínio da conta (ex: cosmicoasis)
INVOICEXPRESS_API_KEY=
INVOICEXPRESS_SERIE=CKL

# --- SMS de reforço dos alertas 🔴 (provider a definir; placeholder) ---
SMS_PROVIDER_KEY=
